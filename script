local function scanAttributes(inst, path)
    pcall(function()
        local attrs = inst:GetAttributes()
        for name, value in pairs(attrs) do
            if containsKeyword(name) or containsKeyword(tostring(value)) then
                log("ATTRIBUTE", string.format(
                    "'%s' = %s (%s) | Tại: %s",
                    name, tostring(value), typeof(value), path
                ))
            end
        end
    end)
end

