print("\n📡 [7/12] QUÉT REMOTE EVENTS & FUNCTIONS...")
local function scanRemotes(parent)
    pcall(function()
        for _, inst in ipairs(parent:GetDescendants()) do
            pcall(function()
                if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction")
                    or inst:IsA("BindableEvent") or inst:IsA("BindableFunction")
                    or inst:IsA("UnreliableRemoteEvent") then
                    if containsKeyword(inst.Name) then
                        log("REMOTE", string.format(
                            "[%s] '%s' | Path: %s",
                            inst.ClassName, inst.Name, safeName(inst)
                        ))
                    end
                end
            end)
        end
    end)
end

