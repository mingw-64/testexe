local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Từ khóa cần tìm (viết thường để so sánh)
local KEYWORDS = {"attack", "defend", "team", "side", "faction", "squad", "group"}
local EXACT_TEAMS = {"attackers", "defenders", "attacker", "defender"}

local results = {}
local scannedCount = 0

-- Hàm tiện ích
local function log(category, msg)
    local entry = "[" .. category .. "] " .. msg
    table.insert(results, entry)
    print(entry)
end

local function containsKeyword(str)
    if type(str) ~= "string" then return false end
    local lower = str:lower()
    for _, kw in ipairs(KEYWORDS) do
        if lower:find(kw) then return true end
    end
    return false
end

local function isExactTeam(str)
    if type(str) ~= "string" then return false end
    local lower = str:lower()
    for _, t in ipairs(EXACT_TEAMS) do
        if lower == t then return true end
    end
    return false
end

local function safeName(inst)
    local success, result = pcall(function()
        return inst:GetFullName()
    end)
    return success and result or "[Không đọc được]"
end

