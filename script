local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- 1. Hàm tạo giao diện hiển thị (Tối ưu cho Mobile)
local function createDisplayGui()
    -- Xóa GUI cũ nếu đã tồn tại để tránh trùng lặp
    if playerGui:FindFirstChild("TeamListMobileGui") then
        playerGui.TeamListMobileGui:Destroy()
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TeamListMobileGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    -- Khung chính (Sử dụng Scale để tự động căn chỉnh trên màn hình điện thoại)
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0.85, 0, 0.75, 0) -- Chiếm 85% chiều rộng, 75% chiều cao
    mainFrame.Position = UDim2.new(0.075, 0, 0.125, 0) -- Căn giữa màn hình
    mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = screenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 15)
    corner.Parent = mainFrame

    -- Nút Đóng (Close Button)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 40, 0, 40)
    closeBtn.Position = UDim2.new(1, -50, 0, 10)
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.TextScaled = true
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Parent = mainFrame
    
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(1, 0) -- Nút tròn
    closeCorner.Parent = closeBtn

    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
    end)

    -- Khung cuộn (ScrollingFrame) để lướt danh sách bằng ngón tay
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, -20, 1, -60)
    scrollFrame.Position = UDim2.new(0, 10, 0, 50)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.ScrollBarThickness = 6
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scrollFrame.Parent = mainFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 8)
    listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    listLayout.Parent = scrollFrame

    return scrollFrame
end

-- Hàm phụ trợ để thêm chữ vào danh sách
local function addTextLabel(parent, text, isTitle)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 0, isTitle and 40 or 30)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = isTitle and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(230, 230, 230)
    label.TextScaled = true
    label.Font = isTitle and Enum.Font.GothamBlack or Enum.Font.GothamSemibold
    label.Parent = parent
end

-- 2. Tìm và trích xuất dữ liệu từ đường dẫn bạn cung cấp
local function fetchAndDisplayTeams()
    -- Sử dụng WaitForChild để đảm bảo GUI gốc đã load xong
    local teamsGui = playerGui:WaitForChild("teams", 5)
    if not teamsGui then return warn("Không tìm thấy GUI 'teams'") end

    local frame1 = teamsGui:WaitForChild("frame")
    local frame2 = frame1:WaitForChild("Frame")

    local attackersNode = frame2:WaitForChild("attackers"):WaitForChild("image"):WaitForChild("players")
    local defendersNode = frame2:WaitForChild("defenders"):WaitForChild("image"):WaitForChild("players")

    -- Tạo GUI hiển thị
    local scrollContainer = createDisplayGui()

    -- Danh sách Attackers
    addTextLabel(scrollContainer, "⚔️ ATTACKERS ⚔️", true)
    local attackerCount = 0
    for _, child in pairs(attackersNode:GetChildren()) do
        if child:IsA("GuiObject") then
            -- Giả định tên người chơi được lưu ở thuộc tính 'Name' của child
            -- Nếu nó nằm trong thuộc tính Text, hãy đổi child.Name thành child.Text
            addTextLabel(scrollContainer, child.Name, false)
            attackerCount = attackerCount + 1
        end
    end
    if attackerCount == 0 then addTextLabel(scrollContainer, "(Trống)", false) end

    -- Khoảng cách
    addTextLabel(scrollContainer, " ", false)

    -- Danh sách Defenders
    addTextLabel(scrollContainer, "🛡️ DEFENDERS 🛡️", true)
    local defenderCount = 0
    for _, child in pairs(defendersNode:GetChildren()) do
        if child:IsA("GuiObject") then
            addTextLabel(scrollContainer, child.Name, false)
            defenderCount = defenderCount + 1
        end
    end
    if defenderCount == 0 then addTextLabel(scrollContainer, "(Trống)", false) end
end

-- Chạy hàm
fetchAndDisplayTeams()
