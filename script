-- 11. QUÉT REGISTRY (getgc nếu executor hỗ trợ)
--========================================
print("\n🧠 [11/12] QUÉT GC REGISTRY (executor only)...")
pcall(function()
    if getgc then
        local gc = getgc(true)
        local gcFound = 0
        for _, obj in ipairs(gc) do
            if type(obj) == "table" then
                for k, v in pairs(obj) do
                    pcall(function()
                        local kStr = tostring(k):lower()
                        local vStr = tostring(v):lower()
                        for _, exact in ipairs(EXACT_TEAMS) do
                            if kStr == exact or vStr == exact then
                                gcFound = gcFound + 1
                                log("GC TABLE", string.format(
                                    "['%s'] = %s (%s)",
                                    tostring(k),
                                    tostring(v):sub(1, 200),
                                    type(v)
                                ))
                                -- In thêm context
                                if gcFound <= 20 then
                                    for k2, v2 in pairs(obj) do
                                        log("GC CONTEXT", string.format(
                                            "  ['%s'] = %s",
                                            tostring(k2):sub(1, 50),
                                            tostring(v2):sub(1, 100)
                                        ))
                                    end
                                end
                            end
                        end
                    end)
                end
            elseif type(obj) == "string" then
                for _, exact in ipairs(EXACT_TEAMS) do
                    if obj:lower():find(exact) then
                        gcFound = gcFound + 1
                        if gcFound <= 30 then
                            log("GC STRING", obj:sub(1, 300))
                        end
                    end
                end
            end
        end
        log("GC SUMMARY", string.format("Tìm thấy %d kết quả trong GC", gcFound))
    else
        log("GC", "⚠️ getgc() không khả dụng (cần executor)")
    end
end)

--========================================
-- 12. QUÉT UPVALUES (nếu executor hỗ trợ)
--========================================
print("\n🔬 [12/12] QUÉT UPVALUES & CONSTANTS...")
pcall(function()
    if getgc and getupvalues then
        local gc = getgc(true)
        local uvFound = 0
        for _, func in ipairs(gc) do
            if type(func) == "function" then
                pcall(function()
                    -- Upvalues
                    local upvals = getupvalues(func)
                    for idx, val in pairs(upvals) do
                        if type(val) == "string" and containsKeyword(val) then
                            uvFound = uvFound + 1
                            if uvFound <= 30 then
                                log("UPVALUE", string.format(
                                    "Function upvalue[%s] = '%s'",
                                    tostring(idx), val:sub(1, 200)
                                ))
                            end
                        elseif type(val) == "table" then
                            for k, v in pairs(val) do
                                if containsKeyword(tostring(k))
                                    or containsKeyword(tostring(v)) then
                                    uvFound = uvFound + 1
                                    if uvFound <= 30 then
                                        log("UPVALUE TABLE", string.format(
                                            "['%s'] = %s",
                                            tostring(k):sub(1, 50),
                                            tostring(v):sub(1, 150)
                                        ))
                                    end
                                end
                            end
                        end
                    end

                    -- Constants
                    if getconstants then
                        local consts = getconstants(func)
                        for idx, val in pairs(consts) do
                            if type(val) == "string" and containsKeyword(val) then
                                uvFound = uvFound + 1
                                if uvFound <= 50 then
                                    log("CONSTANT", string.format(
                                        "Function constant[%d] = '%s'",
                                        idx, val:sub(1, 200)
                                    ))
                                end
                            end
                        end
                    end
                end)
            end
        end
    end
end)

