-- Chức năng bật/tắt UI
toggleBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
end)

-- 5. HÀM TẠO NHÃN TEXT TRONG GUI
local layoutOrderCount = 0
local function createLabel(text, color, isTitle)
    layoutOrderCount = layoutOrderCount + 1
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, isTitle and 30 or 25)
    label.BackgroundTransparency = isTitle and 0.5 or 1
    label.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    label.TextColor3 = color
    label.Text = "  " .. text
    label.TextSize = isTitle and 14 or 12
    label.Font = isTitle and Enum.Font.GothamBold or Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.LayoutOrder = layoutOrderCount
    label.Parent = scrollFrame
    
    if isTitle then
        Instance.new("UICorner", label)
    end
end

-- 6. HÀM CẬP NHẬT DỮ LIỆU TỪ GUI CỦA GAME
local function updateTeamList()
    -- Xóa list cũ
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    layoutOrderCount = 0

    -- Truy cập đường dẫn bạn yêu cầu
    local teamsGui = PlayerGui:FindFirstChild("teams")
    if not teamsGui then
        createLabel("Đang chờ GUI 'teams' load...", Color3.fromRGB(255, 100, 100), true)
        return 
    end
    
    local guiFrame = teamsGui:FindFirstChild("frame") and teamsGui.frame:FindFirstChild("Frame")
    if not guiFrame then return end

    local attackersPath = guiFrame:FindFirstChild("attackers") and guiFrame.attackers:FindFirstChild("image") and guiFrame.attackers.image:FindFirstChild("players")
    local defendersPath = guiFrame:FindFirstChild("defenders") and guiFrame.defenders:FindFirstChild("image") and guiFrame.defenders.image:FindFirstChild("players")

    -- Lấy Attackers
    createLabel("⚔️ TEAM ATTACKERS", Color3.fromRGB(255, 80, 80), true)
    if attackersPath then
        local count = 0
        for _, child in pairs(attackersPath:GetChildren()) do
            if not child:IsA("UIComponent") and child.Name ~= "UIListLayout" and child.Name ~= "UIGridLayout" then
                -- Nếu tên hiển thị nằm trong TextLabel con, bạn đổi child.Name thành child.TextLabel.Text
                createLabel(child.Name, Color3.fromRGB(255, 255, 255), false)
                count = count + 1
            end
        end
        if count == 0 then createLabel("(Trống)", Color3.fromRGB(150, 150, 150), false) end
    end

    -- Lấy Defenders
    createLabel("🛡️ TEAM DEFENDERS", Color3.fromRGB(80, 150, 255), true)
    if defendersPath then
        local count = 0
        for _, child in pairs(defendersPath:GetChildren()) do
            if not child:IsA("UIComponent") and child.Name ~= "UIListLayout" and child.Name ~= "UIGridLayout" then
                createLabel(child.Name, Color3.fromRGB(255, 255, 255), false)
                count = count + 1
            end
        end
        if count == 0 then createLabel("(Trống)", Color3.fromRGB(150, 150, 150), false) end
    end
end

-- 7. VÒNG LẶP AUTO UPDATE (Chỉ update khi đang mở GUI để đỡ lag máy)
task.spawn(function()
    while task.wait(1) do
        if mainFrame.Visible then
            updateTeamList()
        end
    end
end)
