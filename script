-- Chức năng Bật/Tắt GUI
toggleBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
    if mainFrame.Visible then
        toggleBtn.Text = "Đóng Info Player"
    else
        toggleBtn.Text = "Mở Info Player"
    end
end)

-- 5. Hàm cập nhật thông tin
local function updatePlayerList()
    -- Xóa các nhãn cũ để làm mới
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    -- Lặp qua tất cả người chơi trong game
    for _, player in pairs(Players:GetPlayers()) do
        local char = player.Character
        local humanoid = char and char:FindFirstChild("Humanoid")
        
        -- Lấy thông số
        local health = humanoid and math.floor(humanoid.Health) or 0
        local maxHealth = humanoid and math.floor(humanoid.MaxHealth) or 0
        local walkSpeed = humanoid and math.floor(humanoid.WalkSpeed) or 0
        local teamName = player.Team and player.Team.Name or "Không có Đội"
        local displayName = player.DisplayName
        
        -- Tạo một khung nhỏ cho mỗi người chơi
        local playerFrame = Instance.new("Frame")
        playerFrame.Size = UDim2.new(1, 0, 0, 60)
        playerFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        playerFrame.Name = player.Name
        playerFrame.Parent = scrollFrame
        Instance.new("UICorner", playerFrame)
        
        -- Nhãn text hiển thị thông tin
        local infoLabel = Instance.new("TextLabel")
        infoLabel.Size = UDim2.new(1, -10, 1, -10)
        infoLabel.Position = UDim2.new(0, 5, 0, 5)
        infoLabel.BackgroundTransparency = 1
        infoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        infoLabel.Font = Enum.Font.Code
        infoLabel.TextSize = 12
        infoLabel.TextXAlignment = Enum.TextXAlignment.Left
        infoLabel.TextYAlignment = Enum.TextYAlignment.Top
        
        -- Định dạng nội dung hiển thị
        infoLabel.Text = string.format(
            "👤 %s (@%s)\n❤️ HP: %d/%d | ⚡ Tốc độ: %d\n🛡️ Đội: %s",
            displayName, player.Name, health, maxHealth, walkSpeed, teamName
        )
        infoLabel.Parent = playerFrame
    end
end

-- 6. Vòng lặp cập nhật mỗi 1 giây
task.spawn(function()
    while task.wait(1) do
        if mainFrame.Visible then
            updatePlayerList()
        end
    end
end)
