print("\n🌍 [10/12] QUÉT GLOBAL TABLES (_G, shared)...")
local function scanGlobalTable(tableName, t)
    if type(t) ~= "table" then return end
    for key, value in pairs(t) do
        pcall(function()
            if containsKeyword(tostring(key)) or containsKeyword(tostring(value)) then
                log("GLOBAL " .. tableName, string.format(
                    "['%s'] = %s (%s)",
                    tostring(key), tostring(value):sub(1, 200), type(value)
                ))
            end
            if type(value) == "table" then
                for k2, v2 in pairs(value) do
                    if containsKeyword(tostring(k2)) or containsKeyword(tostring(v2)) then
                        log("GLOBAL DEEP", string.format(
                            "%s['%s']['%s'] = %s",
                            tableName, tostring(key), tostring(k2),
                            tostring(v2):sub(1, 200)
                        ))
                    end
                end
            end
        end)
    end
end

