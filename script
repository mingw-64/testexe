local function deepScan(instance, depth)
    if depth > 50 then return end -- Tránh quá sâu
    scannedCount = scannedCount + 1

    pcall(function()
        local name = instance.Name
        local className = instance.ClassName
        local path = safeName(instance)

        -- Kiểm tra tên instance
        if containsKeyword(name) then
            log("INSTANCE NAME", string.format(
                "'%s' [%s] | Path: %s",
                name, className, path
            ))
        end

        -- Kiểm tra Value objects
        if className == "StringValue" then
            pcall(function()
                local val = instance.Value
                if containsKeyword(val) or containsKeyword(name) then
                    log("STRING VALUE", string.format(
                        "'%s' = '%s' | Path: %s",
                        name, val, path
                    ))
                end
            end)
        elseif className == "IntValue" or className == "NumberValue" then
            if containsKeyword(name) then
                pcall(function()
                    log("NUMBER VALUE", string.format(
                        "'%s' = %s | Path: %s",
                        name, tostring(instance.Value), path
                    ))
                end)
            end
        elseif className == "BoolValue" then
            if containsKeyword(name) then
                pcall(function()
                    log("BOOL VALUE", string.format(
                        "'%s' = %s | Path: %s",
                        name, tostring(instance.Value), path
                    ))
                end)
            end
        elseif className == "ObjectValue" then
            if containsKeyword(name) then
                pcall(function()
                    local val = instance.Value
                    log("OBJECT VALUE", string.format(
                        "'%s' = %s | Path: %s",
                        name, val and safeName(val) or "nil", path
                    ))
                end)
            end
        end

        -- Kiểm tra Folder / Model / Configuration có tên liên quan
        if className == "Folder" or className == "Model" or className == "Configuration" then
            if containsKeyword(name) then
                local childCount = 0
                pcall(function()
                    childCount = #instance:GetChildren()
                end)
                log("CONTAINER", string.format(
                    "[%s] '%s' (%d children) | Path: %s",
                    className, name, childCount, path
                ))
            end
        end

        -- Kiểm tra GUI text
        if className == "TextLabel" or className == "TextButton" or className == "TextBox" then
            pcall(function()
                if containsKeyword(instance.Text) then
                    log("GUI TEXT", string.format(
                        "'%s' Text: '%s' | Path: %s",
                        name, instance.Text:sub(1, 100), path
                    ))
                end
            end)
        end

        -- Kiểm tra Attributes
        scanAttributes(instance, path)
    end)

    -- Quét children
    pcall(function()
        for _, child in ipairs(instance:GetChildren()) do
            deepScan(child, depth + 1)
        end
    end)
end

for _, service in ipairs(servicesToScan) do
