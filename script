local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Truy cập vào PlayerGui thay vì StarterGui
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function listPlayersInTeams()
    -- Lấy đường dẫn tới Frame chứa 2 team (Dùng FindFirstChild để không bị lỗi nếu GUI chưa load kịp)
    local teamsGui = PlayerGui:FindFirstChild("teams")
    if not teamsGui then return warn("Không tìm thấy GUI 'teams'") end
    
    local mainFrame = teamsGui:FindFirstChild("frame") and teamsGui.frame:FindFirstChild("Frame")
    if not mainFrame then return warn("Không tìm thấy đường dẫn 'teams.frame.Frame'") end

    -- Lấy thư mục 'players' của team Attackers
    local attackerPlayersPath = mainFrame:FindFirstChild("attackers") 
        and mainFrame.attackers:FindFirstChild("image") 
        and mainFrame.attackers.image:FindFirstChild("players")

    -- Lấy thư mục 'players' của team Defenders
    local defenderPlayersPath = mainFrame:FindFirstChild("defenders") 
        and mainFrame.defenders:FindFirstChild("image") 
        and mainFrame.defenders.image:FindFirstChild("players")

    -- 1. LIỆT KÊ TEAM ATTACKERS
    print("=== TEAM ATTACKERS ===")
    if attackerPlayersPath then
        local count = 0
        for _, child in pairs(attackerPlayersPath:GetChildren()) do
            -- Lọc bỏ các component UI như UIListLayout, UIGridLayout (chỉ lấy các Frame của player)
            if not child:IsA("UIComponent") and child.Name ~= "UIListLayout" and child.Name ~= "UIGridLayout" then
                print("⚔️ " .. child.Name)
                count = count + 1
            end
        end
        if count == 0 then print("(Không có ai)") end
    else
        warn("Không tìm thấy đường dẫn Attackers")
    end

    print("\n=== TEAM DEFENDERS ===")
    -- 2. LIỆT KÊ TEAM DEFENDERS
    if defenderPlayersPath then
        local count = 0
        for _, child in pairs(defenderPlayersPath:GetChildren()) do
            if not child:IsA("UIComponent") and child.Name ~= "UIListLayout" and child.Name ~= "UIGridLayout" then
                print("🛡️ " .. child.Name)
                count = count + 1
            end
        end
        if count == 0 then print("(Không có ai)") end
    else
        warn("Không tìm thấy đường dẫn Defenders")
    end
end

-- Chạy hàm
listPlayersInTeams()
